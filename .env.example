CLAUDE_CODE_OAUTH_TOKEN=<token>
ASSISTANT_NAME=Teri

# Microsoft 365
M365_TENANT_ID=<tenant-id>
M365_CLIENT_ID=<client-id>

# Teams
M365_TEAMS_MODE=discover
M365_TEAMS_POLL_INTERVAL=15000

# Outlook
M365_OUTLOOK_MODE=alias
M365_OUTLOOK_POLL_INTERVAL=60000
M365_OUTLOOK_ALIASES=user@company.com:outlook-main

# Atlassian
ATLASSIAN_BASE_URL=https://yourcompany.atlassian.net
ATLASSIAN_EMAIL=user@company.com
ATLASSIAN_API_TOKEN=<token>

# GitHub (for code search across org repos)
GITHUB_TOKEN=<github-personal-access-token>

# GCP integration is installed via the /add-gcloud skill.
# The gcloud CLI runs on the host; credentials never enter the container.